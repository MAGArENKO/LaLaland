# Project Recovery System - Environment Configuration

# GitHub (optional - for GitHub scraper)
GITHUB_TOKEN=
GITHUB_USERNAME=

# Database
DATABASE_URL=postgresql://recovery:recovery_pass@localhost:5432/project_recovery

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=project_fragments

# Redis
REDIS_URL=redis://localhost:6379

# Argilla (optional - for data labeling)
ARGILLA_API_URL=http://localhost:6900
ARGILLA_API_KEY=admin.apikey
ARGILLA_WORKSPACE=project_recovery

# Processing
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Scheduling
SCRAPE_INTERVAL_HOURS=6
